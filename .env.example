# ============================================================================
# Agentic Wallet Treasury — environment template.
# Copy to .env (or .env.local) and fill in real values before broadcasting.
# Nothing here is required to run `npm run demo`; everything below only matters
# for on-chain registration / execution / feedback.
# ============================================================================

# --- Wallet derivation -------------------------------------------------------
# Option A (recommended): one mnemonic, five derived accounts at standard EVM
# paths m/44'/60'/0'/0/{0..4}. Generate one with:
#   GENERATE_MNEMONIC=1 npm run wallets
# This writes .env.generated (0600) and prints only public addresses by default.
AGENT_MNEMONIC=

# Option B: per-agent private keys (overrides the mnemonic per slot if set).
# SCOUT_PRIVATE_KEY=0x...
# GUARD_PRIVATE_KEY=0x...
# CLAW_PRIVATE_KEY=0x...
# LEDGER_PRIVATE_KEY=0x...
# SENTINEL_PRIVATE_KEY=0x...

# --- Mantle Sepolia ----------------------------------------------------------
MANTLE_SEPOLIA_RPC_URL=https://rpc.sepolia.mantle.xyz
# Set after deploying contracts/src/AgenticTreasury.sol
TREASURY_ADDRESS=

# --- Demo runner -------------------------------------------------------------
# auto | mock | byreal | mantle-sepolia
EXECUTOR=auto
# Used by both the Byreal CLI executor adapter and the Sentinel re-simulator.
#   mock  — deterministic math only (default; works offline)
#   real  — shell out to `byreal-cli` for an independent quote
BYREAL_MODE=mock
# Stable seed for reproducible demos (optional)
DEMO_SEED=demo
# FORCE_SCENARIO=small-stable-rotation | rwa-yield-curve | oversized-action | validator-rejects | hold-cycle

# --- Live chain poller -------------------------------------------------------
POLL_INTERVAL_MS=30000
# POLL_ONCE=1   # take one snapshot and exit (CI / smoke test)

# --- Event watcher -----------------------------------------------------------
WATCH_LOOKBACK_BLOCKS=5000
WATCH_INTERVAL_MS=12000
WATCH_MAX_EVENTS=100
# WATCH_ONCE=1     # backfill once and exit
# WATCH_FIXTURE=1  # write synthetic events.json (no RPC) — useful when offline

# --- Treasury deployer -------------------------------------------------------
# Default 1 ether (1e18 wei). Set per-deploy if you want a tighter cap.
MAX_ACTION_VALUE=1000000000000000000

# --- Agent registration URI strategy -----------------------------------------
# data: embed registration JSON as data: URI (no hosting needed)
# hosted: serve from AGENT_URI_BASE/agents/<slug>.json
AGENT_URI_MODE=data
# AGENT_URI_BASE=https://your-vercel-app.vercel.app
